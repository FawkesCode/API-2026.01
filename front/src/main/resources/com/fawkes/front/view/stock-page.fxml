<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox fx:id="pageContent"
      maxWidth="1200.0"
      minWidth="800.0"
      prefHeight="720.0"
      spacing="16.0"
      styleClass="pageContent"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.fawkes.front.controller.StockPageController">

   <HBox alignment="CENTER_LEFT" spacing="12.0">
      <TextField fx:id="searchField"
                 promptText="Buscar produto..."
                 prefWidth="260.0"
                 onKeyReleased="#handleSearch" />
      <Region HBox.hgrow="ALWAYS" />
      <Button fx:id="btnInput"
              text="+ Entrada"
              styleClass="btn-primary"
              onAction="#handleOpenInputDialog" />
      <Button fx:id="btnOutput"
              text="- Saída"
              styleClass="btn-danger"
              onAction="#handleOpenOutputDialog" />
      <Button fx:id="btnRefresh"
              text="↻ Atualizar"
              onAction="#loadStock" />
   </HBox>

   <TableView fx:id="stockTable" VBox.vgrow="ALWAYS">
      <columns>
         <TableColumn fx:id="colName"    text="Produto"         prefWidth="200.0" />
         <TableColumn fx:id="colType"    text="Tipo"            prefWidth="130.0" />
         <TableColumn fx:id="colUnit"    text="Unidade"         prefWidth="100.0" />
         <TableColumn fx:id="colValue"   text="Valor Unit."     prefWidth="110.0" />
         <TableColumn fx:id="colCurrent" text="Qtd. Atual"      prefWidth="100.0" />
         <TableColumn fx:id="colMin"     text="Mín."            prefWidth="80.0"  />
         <TableColumn fx:id="colMax"     text="Máx."            prefWidth="80.0"  />
      </columns>
      <placeholder>
         <Label text="Nenhum item no estoque." />
      </placeholder>
   </TableView>

   <Label fx:id="statusLabel" text="" />

   <VBox fx:id="inputDialog"
         managed="false" visible="false"
         style="-fx-background-color: white; -fx-border-color: #DADEE3; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 4);"
         maxWidth="400.0"
         spacing="12.0">
      <Label text="Registrar Entrada" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
      <Label text="ID do Estoque:" />
      <TextField fx:id="inputStockId" promptText="Ex: 1" />
      <Label text="ID do Produto:" />
      <TextField fx:id="inputProductId" promptText="Ex: 2" />
      <Label text="Quantidade:" />
      <TextField fx:id="inputQuantity" promptText="Ex: 50" />
      <Label fx:id="inputErrorLabel" text="" style="-fx-text-fill: #FF4A50;" />
      <HBox spacing="10" alignment="CENTER_RIGHT">
         <Button text="Cancelar" onAction="#handleCloseInputDialog" />
         <Button text="Confirmar Entrada" styleClass="btn-primary" onAction="#handleConfirmInput" />
      </HBox>
   </VBox>

   <VBox fx:id="outputDialog"
         managed="false" visible="false"
         style="-fx-background-color: white; -fx-border-color: #DADEE3; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 4);"
         maxWidth="400.0"
         spacing="12.0">
      <Label text="Registrar Saída" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
      <Label text="ID do Estoque:" />
      <TextField fx:id="outputStockId" promptText="Ex: 1" />
      <Label text="ID do Produto:" />
      <TextField fx:id="outputProductId" promptText="Ex: 2" />
      <Label text="Quantidade:" />
      <TextField fx:id="outputQuantity" promptText="Ex: 10" />
      <Label fx:id="outputErrorLabel" text="" style="-fx-text-fill: #FF4A50;" />
      <HBox spacing="10" alignment="CENTER_RIGHT">
         <Button text="Cancelar" onAction="#handleCloseOutputDialog" />
         <Button text="Confirmar Saída" styleClass="btn-danger" onAction="#handleConfirmOutput" />
      </HBox>
   </VBox>

</VBox>
