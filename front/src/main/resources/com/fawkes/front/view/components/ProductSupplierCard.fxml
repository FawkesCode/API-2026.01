      <HBox alignment="CENTER" prefHeight="47.0" prefWidth="215.0" spacing="10.0" style="-fx-padding: 6 10;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
