<?xml version="1.0" encoding="UTF-8"?>

<?import com.jfoenix.controls.JFXButton?>
<?import java.lang.String?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="pageContent" maxWidth="1200.0" minWidth="800.0" prefHeight="720.0" spacing="16.0" styleClass="pageContent" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.fawkes.front.controller.ProductsPageController">

   <HBox alignment="CENTER_LEFT" spacing="12.0">
      <TextField fx:id="searchField" onKeyPressed="#handleSearch" prefWidth="280.0" promptText="Pesquisar por um produto...">
         <styleClass>
            <String fx:value="input__text" />
            <String fx:value="input__text--search" />
         </styleClass></TextField>
      <Region HBox.hgrow="ALWAYS" />
      <JFXButton onAction="#handleBackButton" ripplerFill="#465161" styleClass="btn--link" text="Voltar" />
      <JFXButton fx:id="btnInput" onAction="#handleAddSupplier" styleClass="btn--primary" text="Novo Produto">
         <graphic>
            <ImageView fitHeight="16.0" fitWidth="16.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../img/add-icon.png" />
               </image>
            </ImageView>
         </graphic>
      </JFXButton>
   </HBox>
   <VBox fx:id="productsContainer" prefHeight="200.0" prefWidth="100.0" spacing="20.0" VBox.vgrow="ALWAYS" />

