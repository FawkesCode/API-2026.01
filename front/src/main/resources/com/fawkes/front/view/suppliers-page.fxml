<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="pageContent" maxWidth="1200.0" minWidth="800.0" prefHeight="720.0"
      styleClass="pageContent" spacing="16"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.fawkes.front.controller.SupplierPageController">

   <HBox alignment="CENTER_LEFT" spacing="12">
      <TextField fx:id="searchField" promptText="Buscar fornecedor..." prefWidth="260" onKeyReleased="#handleSearch"/>
      <Region HBox.hgrow="ALWAYS"/>
      <Button text="+ Novo Fornecedor" styleClass="btn-primary" onAction="#handleOpenAddDialog"/>
      <Button text="Atualizar" onAction="#loadSuppliers"/>
   </HBox>

   <TableView fx:id="supplierTable" VBox.vgrow="ALWAYS">
      <columns>
         <TableColumn fx:id="colId"       text="ID"              prefWidth="60"/>
         <TableColumn fx:id="colNome"     text="Nome"            prefWidth="300"/>
         <TableColumn fx:id="colCnpj"     text="CNPJ"           prefWidth="180"/>
         <TableColumn fx:id="colPagamento" text="Pagamento"      prefWidth="120"/>
         <TableColumn fx:id="colAcoes"    text="Acoes"           prefWidth="100"/>
      </columns>
      <placeholder>
         <Label text="Nenhum fornecedor cadastrado."/>
      </placeholder>
   </TableView>

   <Label fx:id="statusLabel" text=""/>

   <VBox fx:id="addDialog" visible="false" managed="false"
         style="-fx-background-color: white; -fx-border-color: #DADEE3; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 4);"
         maxWidth="400" spacing="12">
      <Label text="Novo Fornecedor" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
      <Label text="Nome:"/>
      <TextField fx:id="fieldNome" promptText="Nome do fornecedor"/>
      <Label text="CNPJ:"/>
      <TextField fx:id="fieldCnpj" promptText="00.000.000/0000-00"/>
      <Label text="Meio de Pagamento:"/>
      <ComboBox fx:id="comboPagamento" prefWidth="200"/>
      <Label fx:id="addErrorLabel" text="" style="-fx-text-fill: #FF4A50;"/>
      <HBox spacing="10" alignment="CENTER_RIGHT">
         <Button text="Cancelar" onAction="#handleCloseAddDialog"/>
         <Button text="Cadastrar" styleClass="btn-primary" onAction="#handleConfirmAdd"/>
      </HBox>
   </VBox>

</VBox>