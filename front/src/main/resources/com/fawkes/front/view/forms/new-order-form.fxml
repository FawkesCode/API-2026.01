<?xml version="1.0" encoding="UTF-8"?>

<?import com.jfoenix.controls.JFXButton?>
<?import java.lang.String?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane
        prefHeight="364.0" prefWidth="800.0"
        xmlns="http://javafx.com/javafx/25"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.fawkes.front.controller.NewOrderFormController">

    <children>

        <!-- Linha 1: Fornecedor + Método de Pagamento -->
        <HBox layoutX="40.0" layoutY="20.0" prefWidth="720.0" spacing="0.0">
            <children>
                <AnchorPane prefHeight="80.0" prefWidth="360.0">
                    <children>
                        <Label styleClass="input__label" text="Fornecedor*:"
                               AnchorPane.leftAnchor="10.0" AnchorPane.topAnchor="8.0"/>
                        <ComboBox fx:id="supplierCombo" promptText="Selecionar"
                                  styleClass="input__text"
                                  AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0"
                                  AnchorPane.topAnchor="30.0"/>
                    </children>
                </AnchorPane>
                <AnchorPane prefHeight="80.0" prefWidth="360.0">
                    <children>
                        <Label styleClass="input__label" text="Método de Pagamento*:"
                               AnchorPane.leftAnchor="10.0" AnchorPane.topAnchor="8.0"/>
                        <ComboBox fx:id="paymentCombo" promptText="Selecionar"
                                  styleClass="input__text"
                                  AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0"
                                  AnchorPane.topAnchor="30.0"/>
                    </children>
                </AnchorPane>
            </children>
        </HBox>

        <!-- Linha 2: Produto + Quantidade -->
        <HBox layoutX="40.0" layoutY="105.0" prefWidth="720.0" spacing="0.0">
            <children>
                <AnchorPane prefHeight="80.0" prefWidth="520.0">
                    <children>
                        <Label styleClass="input__label" text="Produto*:"
                               AnchorPane.leftAnchor="10.0" AnchorPane.topAnchor="8.0"/>
                        <ComboBox fx:id="productCombo" promptText="Selecionar produto"
                                  styleClass="input__text"
                                  AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0"
                                  AnchorPane.topAnchor="30.0"/>
                    </children>
                </AnchorPane>
                <AnchorPane prefHeight="80.0" prefWidth="200.0">
                    <children>
                        <Label styleClass="input__label" text="Quantidade*:"
                               AnchorPane.leftAnchor="10.0" AnchorPane.topAnchor="8.0"/>
                        <TextField fx:id="quantityField" promptText="0"
                                   AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0"
                                   AnchorPane.topAnchor="30.0">
                            <styleClass>
                                <String fx:value="input__text"/>
                                <String fx:value="input__text--form"/>
                            </styleClass>
                        </TextField>
                    </children>
                </AnchorPane>
            </children>
        </HBox>

        <!-- Linha 3: Justificativa -->
        <VBox layoutX="50.0" layoutY="190.0" prefWidth="700.0" spacing="6.0">
            <Label styleClass="input__label" text="Justificativa / Observação:"/>
            <TextArea fx:id="descriptionField"
                      promptText="Descreva o motivo da solicitação..."
                      prefHeight="80.0" wrapText="true">
                <styleClass>
                    <String fx:value="input__text"/>
                    <String fx:value="input__text--form"/>
                </styleClass>
            </TextArea>
        </VBox>

        <!-- Erro -->
        <Label fx:id="errorLabel"
               layoutX="50.0" layoutY="288.0"
               prefHeight="20.0" prefWidth="500.0"
               styleClass="input__label--error" wrapText="true"/>

        <!-- Botões -->
        <HBox alignment="CENTER_RIGHT"
              layoutX="430.0" layoutY="316.0"
              prefWidth="330.0"
              spacing="15.0">
            <children>
                <JFXButton fx:id="btnSubmit" onAction="#handleOnSubmit"
                           styleClass="btn--submit" text="Abrir Pedido"/>
                <JFXButton fx:id="btnClose" onAction="#closeModal"
                           styleClass="btn--cancel" text="Cancelar"/>
            </children>
        </HBox>

    </children>
</AnchorPane>
