<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="pageContent" maxWidth="1200.0" minWidth="800.0" prefHeight="720.0"
      styleClass="pageContent" spacing="16"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.fawkes.front.controller.EmployeePageController">

   <HBox alignment="CENTER_LEFT" spacing="12">
      <TextField fx:id="searchField" promptText="Buscar funcionario..." prefWidth="260" onKeyReleased="#handleSearch"/>
      <Region HBox.hgrow="ALWAYS"/>
      <Button text="+ Novo Funcionario" styleClass="btn-primary" onAction="#handleOpenAddDialog"/>
      <Button text="Atualizar" onAction="#loadEmployees"/>
   </HBox>

   <TableView fx:id="employeeTable" VBox.vgrow="ALWAYS">
      <columns>
         <TableColumn fx:id="colId"       text="ID"          prefWidth="60"/>
         <TableColumn fx:id="colNome"     text="Nome"        prefWidth="200"/>
         <TableColumn fx:id="colEmail"    text="Email"       prefWidth="220"/>
         <TableColumn fx:id="colAtivo"    text="Ativo"       prefWidth="80"/>
         <TableColumn fx:id="colGrupo"    text="Grupo"       prefWidth="120"/>
         <TableColumn fx:id="colDepto"    text="Departamento" prefWidth="150"/>
         <TableColumn fx:id="colAcoes"    text="Acoes"       prefWidth="100"/>
      </columns>
      <placeholder>
         <Label text="Nenhum funcionario cadastrado."/>
      </placeholder>
   </TableView>

   <Label fx:id="statusLabel" text=""/>

   <VBox fx:id="addDialog" visible="false" managed="false"
         style="-fx-background-color: white; -fx-border-color: #DADEE3; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 4);"
         maxWidth="400" spacing="12">
      <Label text="Novo Funcionario" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
      <Label text="Nome de usuario:"/>
      <TextField fx:id="fieldUsername" promptText="usuario123"/>
      <Label text="Email:"/>
      <TextField fx:id="fieldEmail" promptText="email@empresa.com"/>
      <Label text="Senha:"/>
      <PasswordField fx:id="fieldPassword"/>
      <Label text="ID do Grupo:"/>
      <TextField fx:id="fieldGroupId" promptText="Ex: 1"/>
      <Label text="ID do Departamento:"/>
      <TextField fx:id="fieldDeptId" promptText="Ex: 1"/>
      <Label fx:id="addErrorLabel" text="" style="-fx-text-fill: #FF4A50;"/>
      <HBox spacing="10" alignment="CENTER_RIGHT">
         <Button text="Cancelar" onAction="#handleCloseAddDialog"/>
         <Button text="Cadastrar" styleClass="btn-primary" onAction="#handleConfirmAdd"/>
      </HBox>
   </VBox>

</VBox>