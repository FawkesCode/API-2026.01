<?xml version="1.0" encoding="UTF-8"?>

<?import com.jfoenix.controls.JFXButton?>
<?import java.lang.String?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="pageContent" maxWidth="1200.0" minWidth="800.0" prefHeight="720.0" spacing="16.0" styleClass="pageContent" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.fawkes.front.controller.RequestProductsPageController">
   <children>
      <HBox alignment="CENTER_LEFT" spacing="12">
         <children>
            <JFXButton fx:id="newEmployee" onAction="#handleAddToCart" styleClass="btn--cart" text="Ver itens adicionados ao carrinho &gt;" />
            <Region prefHeight="26.0" prefWidth="298.0" HBox.hgrow="ALWAYS" />
            <TextField fx:id="searchField" onKeyReleased="#handleSearch" prefHeight="26.0" prefWidth="280.0" promptText="Buscar funcionario...">
               <styleClass>
                  <String fx:value="input__text" />
                  <String fx:value="input__text--search" />
               </styleClass>
            </TextField>
            <JFXButton onAction="#handleBackButton" ripplerFill="#465161" styleClass="btn--link" text="Voltar" />
         </children>
      </HBox>
      <VBox fx:id="productsContainer" prefHeight="209.0" prefWidth="854.0" spacing="30.0" VBox.vgrow="ALWAYS" />
   </children>
</VBox>
